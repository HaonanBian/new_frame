{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "BuildProject",
            "type": "shell",
            "command": "./run.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 run.sh 脚本构建项目"
        },
        {
            "label": "CleanBuild",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "build"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "清理构建目录"
        },
        {
            "label": "Build and Flash",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Project",
                "Flash Device"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            },
            "detail": "先构建项目，然后烧录到设备"
        },
        {
            "label": "FlashDevice",
            "type": "shell",
            "command": "./jlink.sh",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "detail": "使用 J-Link 烧录程序到设备"
        }
    ]
}